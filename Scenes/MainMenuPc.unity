--- !u!114 &1809929674
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1809929672}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Dev Log Version 1.0.3\n\nUpdated skills to have different random values
    ie 10%, 20%, 30%, 40%, 50%.\n\nAdded weapon classes \n\nHeavy: base weapon starts
    as the missile\n\nHoming: base weapon starts as the drones\n\nRapid: base weapon
    starts as the minigun\n\nAdded some more skills:\n\nArray shot: unlocks an auto
    weapon that shoots a burst of bullets every 5 seconds\n\nArray delay: decreases
    the delay between each array shot by 1 second\n\nArray double shot: makes the
    array shot shoot twice\n\nMulti shot: each shot is followed up by another shot
    reduces damage by 40%\n\nUpdated Skills\n\nDouble shot: now reduces damage by
    40%\n\nBackwards fire: now reduces damage by 20%\n\nAdded Another Weapon\n\nLaser
    weapon: Gain a laser gun as an extra weapon\n\nUpdates some weapons\n\nDrone
    weapon: made it so it's affected by upgrades such as double shot balancing it
    for early game\n\nMinigun weapon: reduced the fire rate, reduced the base burst
    amount, and added spread to the bullets making it more balanced for early game\n\nExtras\n\nAdded
    visual effects to poison\n\nAdded another setting menu for game settings currently
    (Enemy health / Enemy damage bonus / Enemy spawn rate / Enemy base max spawn
    count) meant for player controlled balancing in case the game is too hard or
    easy"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: b03b992b2252dab4c9668a1b0eba5b93, type: 2}
  m_sharedMaterial: {fileID: -5243488613788892683, guid: b03b992b2252dab4c9668a1b0eba5b93, type: 2}
